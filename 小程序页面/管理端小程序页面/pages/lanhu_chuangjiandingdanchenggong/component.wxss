.page {
  background-color: rgba(255,255,255,1.000000);
  position: relative;
  width: 750rpx;
  height: 768rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.group_1 {
  background-color: rgba(0,0,0,0.600000);
  height: 1200rpx;
  margin-top: -216rpx;
  display: flex;
  flex-direction: column;
  width: 750rpx;
}
.section_1 {
  background-image: linear-gradient(360deg, rgba(243,252,242,1.000000) 0, rgba(255,255,255,1.000000) 50.000000%);
  border-radius: 36rpx;
  height: 248rpx;
  display: flex;
  flex-direction: column;
  width: 506rpx;
  margin: 508rpx 0 0 122rpx;
}
.group_2 {
  border-radius: 36rpx;
  width: 506rpx;
  height: 200rpx;
  border: 1.5px gradient ;
  margin-top: 2rpx;
  display: flex;
  flex-direction: column;
}
.image-wrapper_1 {
  height: 128rpx;
  background: url(data:image/png;base64,) 100% no-repeat;
  background-size: 100% 100%;
  margin-top: -2rpx;
  display: flex;
  flex-direction: column;
  width: 506rpx;
}
.image_1 {
  width: 144rpx;
  height: 144rpx;
  margin: -46rpx 0 0 168rpx;
}
.text_1 {
  width: 424rpx;
  height: 42rpx;
  overflow-wrap: break-word;
  color: rgba(36,45,42,1.000000);
  font-size: 28rpx;
  font-family: Source Han Sans CN-Medium;
  font-weight: 500;
  text-align: center;
  white-space: nowrap;
