.detail-order-page {
  padding-bottom: 48rpx;
}

.status-panel {
  margin-top: -70rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #2b2627, #705e08);
  color: #fff;
}

.status-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.status-panel .muted {
  color: rgba(255, 255, 255, 0.72);
}

.status-btn {
  margin-top: 28rpx;
}

.status-link {
  margin-top: 20rpx;
  padding: 0;
  background: transparent;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  line-height: 36rpx;
  text-align: left;
}

.steps,
.summary,
.fee-card {
  margin-top: 20rpx;
  padding: 28rpx;
}

.step {
  height: 56rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  color: rgba(43, 38, 39, 0.48);
}

.step-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #eaeaea;
}

.step-on {
  color: #2b2627;
  font-weight: 600;
}

.step-on .step-dot {
  background: #fcd41d;
}

.summary-head {
  display: flex;
  gap: 20rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.summary-img {
  width: 160rpx;
  height: 120rpx;
  border-radius: 16rpx;
}

.car-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.time-pair {
  height: 120rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f5f5f5;
}

.time-pair view {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-weight: 600;
}

.label {
  color: rgba(43, 38, 39, 0.55);
  font-size: 22rpx;
  font-weight: 400;
}

.duration {
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 24rpx;
  border: 1rpx solid #eaeaea;
  line-height: 46rpx;
  font-size: 22rpx;
  font-weight: 400;
}

.right {
  text-align: right;
}

.address-line {
  height: 82rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.address-line:last-child {
  border-bottom: none;
}

.tag {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  line-height: 48rpx;
  text-align: center;
  font-weight: 700;
}

.yellow {
  background: #fcd41d;
}

.dark {
  background: #2b2627;
  color: #fff;
}

.block-title {
  font-weight: 600;
  margin-bottom: 24rpx;
}

.fee-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.fee-switch {
  color: rgba(43, 38, 39, 0.52);
  font-size: 22rpx;
}

.fee-row {
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: rgba(43, 38, 39, 0.65);
}

.total {
  color: #2b2627;
  font-size: 34rpx;
  font-weight: 600;
  border-top: 1rpx solid #f5f5f5;
  margin-top: 12rpx;
  padding-top: 16rpx;
}
