.confirm-page {
  padding-bottom: calc(142rpx + env(safe-area-inset-bottom));
}

.order-car {
  margin-top: -70rpx;
  padding: 24rpx;
}

.car-top {
  display: flex;
  gap: 16rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-img {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
}

.order-car-info {
  flex: 1;
  font-size: 24rpx;
  line-height: 40rpx;
}

.line {
  display: flex;
  gap: 26rpx;
  flex-wrap: wrap;
}

.time-line {
  height: 128rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f5f5f5;
}

.time-line view {
  width: 170rpx;
}

.label {
  display: block;
  color: rgba(43, 38, 39, 0.6);
  font-size: 22rpx;
}

.strong {
  display: block;
  margin-top: 8rpx;
  font-weight: 600;
}

.duration {
  min-width: 158rpx;
  height: 48rpx;
  border: 1rpx solid #eaeaea;
  border-radius: 24rpx;
  text-align: center;
  line-height: 46rpx;
  font-size: 22rpx;
}

.right {
  text-align: right;
}

.fee-line {
  height: 56rpx;
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  font-size: 26rpx;
}

.amount {
  margin-left: auto;
  font-weight: 600;
}

.delivery,
.user-card,
.remark-card,
.deposit,
.fee-card {
  margin-top: 20rpx;
  padding: 24rpx;
}

.switch-head {
  height: 76rpx;
  margin: -24rpx -24rpx 16rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  text-align: center;
  font-weight: 600;
  background: linear-gradient(110deg, #fff 0%, #fff 50%, #fef0bf 50%, #fff7df 100%);
  border-radius: 24rpx 24rpx 0 0;
}

.switch-head .active {
  color: #aa581e;
}

.address-row {
  min-height: 114rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.delivery-tip {
  margin: 16rpx 0 20rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #fef8de;
  color: rgba(43, 38, 39, 0.68);
  font-size: 22rpx;
  line-height: 34rpx;
}

.tag {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  line-height: 48rpx;
  text-align: center;
  font-weight: 700;
}

.yellow {
  background: #fcd41d;
}

.dark {
  background: #2b2627;
  color: #fff;
}

.label-name {
  font-weight: 600;
  white-space: nowrap;
}

.user-card {
  height: 112rpx;
  display: flex;
  align-items: center;
}

.block-title {
  font-size: 26rpx;
  font-weight: 600;
}

.verify-btn {
  margin-left: auto;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 16rpx;
  background: linear-gradient(90deg, #fcd41d, #fef9e5);
  line-height: 56rpx;
  font-size: 22rpx;
}

.remark-card {
  height: 360rpx;
}

.remark-area {
  width: 100%;
  height: 240rpx;
  margin-top: 22rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(43, 38, 39, 0.1);
  border-radius: 24rpx;
  color: #2b2627;
  font-size: 26rpx;
}

.notice-card {
  width: 686rpx;
  margin: 20rpx auto 0;
  border: 1rpx solid #fcf0b9;
  border-radius: 24rpx;
  overflow: hidden;
  background: #fff;
}

.notice-title {
  height: 80rpx;
  padding: 24rpx 32rpx 0;
  background: linear-gradient(115deg, #fef8de 0%, #fef8de 44%, #fff 44%, #fff 100%);
  font-weight: 600;
}

.notice-body {
  padding: 24rpx 32rpx;
}

.notice-body view {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
  font-size: 26rpx;
}

.notice-body view:last-child {
  margin-bottom: 0;
}

.credit-tip {
  height: 72rpx;
  margin: 24rpx 0 16rpx;
  padding: 0 12rpx 0 20rpx;
  border-radius: 16rpx;
  background: #2b2627;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 22rpx;
}

.credit-tip button {
  height: 48rpx;
  padding: 0 12rpx;
  border-radius: 12rpx;
  background: #fef8de;
  color: #2b2627;
  line-height: 48rpx;
}

.deposit-box {
  border: 1rpx solid #fcf0b9;
  border-radius: 16rpx;
  overflow: hidden;
}

.deposit-box view {
  display: grid;
  grid-template-columns: 94rpx 120rpx 1fr 154rpx;
  gap: 10rpx;
  align-items: center;
  min-height: 80rpx;
  padding: 0 20rpx;
  font-size: 22rpx;
}

.deposit-box view + view {
  border-top: 1rpx solid #fcf0b9;
}

.reduce {
  height: 48rpx;
  border-radius: 12rpx;
  background: linear-gradient(90deg, #fef9e5, #fcd41d);
  line-height: 48rpx;
  text-align: center;
}

.deposit-note {
  margin-top: 20rpx;
  font-size: 22rpx;
}

.fee-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.fee-switch {
  color: rgba(43, 38, 39, 0.52);
  font-size: 22rpx;
}

.fee-detail {
  margin-top: 18rpx;
  border-top: 1rpx solid #f5f5f5;
  padding-top: 8rpx;
}

.fee-detail-row {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: rgba(43, 38, 39, 0.72);
  font-size: 24rpx;
}

.total-row {
  color: #2b2627;
  font-size: 28rpx;
  font-weight: 600;
}

.pay-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  height: calc(128rpx + env(safe-area-inset-bottom));
  padding: 24rpx 32rpx env(safe-area-inset-bottom);
  display: flex;
  gap: 32rpx;
  background: #fff;
  border-top: 1rpx solid #f5f5f5;
}

.pay-price {
  width: 128rpx;
}

.pay-num {
  font-size: 52rpx;
  font-weight: 700;
}

.fee-tag {
  display: inline-block;
  min-width: 112rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx 16rpx 4rpx 16rpx;
  background: #fcd41d;
  font-size: 22rpx;
}

.pay-btn {
  flex: 1;
}
