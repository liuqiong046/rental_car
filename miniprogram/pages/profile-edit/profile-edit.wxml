<view class="page profile-edit-page">
  <view class="nav nav-light" style="height: {{nav.navHeight}}px; padding-top: {{nav.statusBarHeight}}px;">
    <button class="nav-back" style="top: {{nav.menuTop}}px; height: {{nav.menuHeight}}px;" bindtap="goBack">‹</button>
    <text class="nav-title" style="margin-top: {{nav.menuOffset}}px;">个人信息</text>
  </view>

  <view class="edit-card card">
    <view class="row row-avatar row-link" bindtap="chooseAvatar">
      <text class="row-label">头像</text>
      <view class="row-tail">
        <view class="avatar-preview">
          <image wx:if="{{avatarUrl}}" class="avatar-image" src="{{avatarUrl}}" mode="aspectFill" />
          <text wx:else class="avatar-fallback">{{profile.avatar_text || "山"}}</text>
        </view>
        <text class="row-arrow">›</text>
      </view>
    </view>
    <view class="divider"></view>
    <view class="row">
      <text class="row-label">昵称</text>
      <input value="{{nickname}}" maxlength="24" placeholder="请输入昵称" bindinput="onNicknameInput" />
    </view>
    <view class="divider"></view>
    <view class="row row-link" bindtap="openPhoneEdit">
      <text class="row-label">手机号</text>
      <view class="row-tail">
        <text class="row-value">{{profile.phone_mask || "未登录"}}</text>
        <text class="row-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="fixed-action">
    <button class="btn-yellow fixed-btn" loading="{{savingProfile}}" bindtap="saveProfile">确认修改</button>
  </view>
</view>
