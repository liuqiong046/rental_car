.profile-edit-page {
  background: #fff;
  padding-bottom: calc(176rpx + env(safe-area-inset-bottom));
}

.edit-card {
  margin-top: 24rpx;
  padding: 0 32rpx;
}

.row {
  min-height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.row-avatar {
  min-height: 128rpx;
}

.row-link {
  cursor: pointer;
}

.row-label {
  color: #2b2627;
  font-size: 28rpx;
}

.row input,
.row-value {
  flex: 1;
  min-width: 0;
  color: rgba(43, 38, 39, 0.42);
  font-size: 28rpx;
  text-align: right;
}

.row-tail {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.divider {
  height: 1rpx;
  background: #f5f5f5;
}

.avatar-preview {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: #2b2627;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  color: #fff;
  text-align: center;
  line-height: 96rpx;
  font-size: 36rpx;
  font-weight: 600;
}

.row-arrow {
  color: rgba(43, 38, 39, 0.36);
  font-size: 36rpx;
  line-height: 1;
}

.fixed-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #fff 32%);
}

.fixed-btn {
  width: 686rpx;
  margin: 0 auto;
}
