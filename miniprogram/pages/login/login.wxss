.login-page {
  position: relative;
  min-height: 100vh;
  padding-bottom: calc(96rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  overflow: hidden;
}

.login-bg {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  overflow: hidden;
}

.ring {
  position: absolute;
  border-radius: 999rpx;
  border: 6rpx solid rgba(210, 189, 103, 0.08);
}

.ring-top {
  top: -232rpx;
  left: -176rpx;
}

.ring-top-main {
  width: 468rpx;
  height: 468rpx;
  border-color: rgba(252, 212, 29, 0.24);
  box-shadow: 0 0 44rpx rgba(252, 212, 29, 0.14);
}

.ring-top-second {
  top: -198rpx;
  left: -112rpx;
  width: 574rpx;
  height: 574rpx;
}

.ring-top-third {
  top: -154rpx;
  left: -42rpx;
  width: 676rpx;
  height: 676rpx;
}

.ring-bottom {
  right: -226rpx;
  bottom: -220rpx;
}

.ring-bottom-main {
  width: 404rpx;
  height: 404rpx;
  border-color: rgba(252, 212, 29, 0.18);
  box-shadow: 0 0 36rpx rgba(252, 212, 29, 0.1);
}

.ring-bottom-second {
  right: -154rpx;
  bottom: -162rpx;
  width: 516rpx;
  height: 516rpx;
}

.ring-bottom-third {
  right: -76rpx;
  bottom: -96rpx;
  width: 626rpx;
  height: 626rpx;
}

.login-nav {
  position: relative;
  z-index: 2;
  color: #2b2627;
  background: transparent;
}

.login-back {
  left: 24rpx;
  width: 48rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.login-back-icon {
  width: 34rpx;
  height: 34rpx;
}

.login-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  width: 260rpx;
  color: #2b2627;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
}

.login-content {
  position: relative;
  z-index: 2;
  width: 590rpx;
  margin: 166rpx auto 0;
}

.brand-logo {
  width: 96rpx;
  height: 96rpx;
}

.hero-title {
  display: block;
  margin-top: 34rpx;
  color: #2b2627;
  font-size: 58rpx;
  font-weight: 700;
  line-height: 74rpx;
}

.hero-desc {
  display: block;
  margin-top: 18rpx;
  color: rgba(43, 38, 39, 0.58);
  font-size: 24rpx;
  line-height: 34rpx;
}

.form-group {
  margin-top: 108rpx;
}

.field {
  min-height: 88rpx;
  padding: 0 22rpx;
  border: 2rpx solid rgba(43, 38, 39, 0.1);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.field + .field {
  margin-top: 24rpx;
}

.field-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
}

.field-icon-image {
  width: 40rpx;
  height: 40rpx;
  flex: 0 0 auto;
}

.field-divider,
.code-divider {
  width: 2rpx;
  height: 42rpx;
  margin: 0 24rpx;
  background: rgba(43, 38, 39, 0.1);
}

.field-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  color: #2b2627;
  font-size: 30rpx;
  font-weight: 500;
}

.field-placeholder {
  color: rgba(43, 38, 39, 0.32);
  font-size: 30rpx;
  font-weight: 400;
}

.field-clear {
  flex: 0 0 auto;
  width: 42rpx;
  height: 42rpx;
  border-radius: 21rpx;
  background: #dddddd;
  color: #ffffff;
  text-align: center;
  line-height: 42rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.field-code {
  min-height: 96rpx;
  padding-right: 12rpx;
}

.code-input {
  height: 92rpx;
  padding-left: 8rpx;
  font-size: 32rpx;
}

.field-code .code-divider {
  margin: 0 16rpx;
}

.code-btn {
  flex: 0 0 auto;
  width: 156rpx;
  /* height: 92rpx; */
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  color: #e0b400;
  text-align: center;
  line-height: 1;
  font-size: 30rpx;
  font-weight: 500;
}

.code-btn-disabled {
  color: #d8ab00;
}

.submit-btn {
  display: block;
  width: 100%;
  height: 88rpx;
  margin-top: 48rpx;
  border-radius: 24rpx;
  text-align: center;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.submit-btn-active {
  background: #2f2929;
  color: #ffffff;
}

.submit-btn-disabled {
  background: #dfddda;
  color: rgba(255, 255, 255, 0.96);
}

.agreement-row {
  margin-top: 34rpx;
  display: flex;
  align-items: center;
}

.agreement-checker {
  flex: 0 0 auto;
  padding-right: 14rpx;
  display: flex;
  align-items: center;
}

.agreement-circle {
  width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(43, 38, 39, 0.12);
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.agreement-circle-checked {
  border-color: #2f2929;
  background: #2f2929;
}

.agreement-tick {
  color: #fcd41d;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.agreement-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.agreement-copy-muted,
.agreement-copy-link {
  font-size: 22rpx;
  line-height: 34rpx;
}

.agreement-copy-muted {
  color: rgba(43, 38, 39, 0.62);
}

.agreement-copy-link {
  color: #e0b400;
}

.agreement-modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 40;
  background: rgba(30, 26, 27, 0.52);
  backdrop-filter: blur(6rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 44rpx;
}

.agreement-modal {
  width: 100%;
  max-width: 540rpx;
  padding: 44rpx 40rpx 40rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 64rpx rgba(27, 22, 14, 0.18);
}

.agreement-modal-warning {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto 24rpx;
  border-radius: 44rpx;
  background: #fff3bf;
  border: 2rpx solid #ffe08a;
}

.warning-mark {
  color: #2f2929;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
}

.agreement-modal-title {
  display: block;
  color: #2f2929;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.agreement-modal-content {
  display: block;
  color: rgba(43, 38, 39, 0.72);
  text-align: center;
  font-size: 24rpx;
  line-height: 36rpx;
  margin-top: 14rpx;
}

.agreement-modal-content-second {
  margin-top: 0;
}

.agreement-modal-btn {
  display: block;
  height: 88rpx;
  margin-top: 32rpx;
  border-radius: 24rpx;
  background: #2f2929;
  color: #ffffff;
  text-align: center;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 24rpx rgba(47, 41, 41, 0.2);
}
