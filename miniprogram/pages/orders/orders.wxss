.orders-page {
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
}

.order-tabs {
  white-space: nowrap;
  height: 88rpx;
  margin-top: -70rpx;
  padding-left: 32rpx;
}

.order-tab {
  display: inline-block;
  margin-right: 40rpx;
  height: 64rpx;
  line-height: 64rpx;
  color: rgba(43, 38, 39, 0.62);
}

.order-tab-active {
  color: #2b2627;
  font-size: 34rpx;
  font-weight: 600;
  position: relative;
}

.order-tab-active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: 2rpx;
  width: 24rpx;
  height: 8rpx;
  margin-left: -12rpx;
  border-radius: 4rpx;
  background: #fcd41d;
}

.order-list {
  padding-top: 8rpx;
}

.order-card {
  position: relative;
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.order-head,
.order-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 24rpx;
}

.status {
  color: #aa581e;
}

.order-no {
  max-width: 480rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-user {
  height: 88rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  border-bottom: 1rpx solid #f5f5f5;
  font-weight: 600;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #fcd41d;
  text-align: center;
  line-height: 64rpx;
  font-size: 22rpx;
}

.phone {
  margin-left: auto;
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #f8f8f7;
  line-height: 64rpx;
}

.trip-mini {
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.trip-mini view {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.duration {
  height: 48rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid #eaeaea;
  line-height: 46rpx;
  font-size: 22rpx;
}

.right {
  text-align: right;
}

.car-strip {
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #f8f8f7;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.plate {
  min-width: 216rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: #fff;
  text-align: center;
  line-height: 48rpx;
}

.order-foot {
  margin-top: 20rpx;
}

.fee {
  font-size: 34rpx;
  font-weight: 600;
}
