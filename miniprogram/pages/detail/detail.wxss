.detail-page {
  background: #fff;
  padding-bottom: calc(128rpx + env(safe-area-inset-bottom));
}

.detail-nav {
  height: 206rpx;
}

.hero-image {
  display: block;
  width: 686rpx;
  height: 480rpx;
  margin: -4rpx auto 24rpx;
  border-radius: 32rpx;
}

.gallery {
  width: 686rpx;
  margin: 0 auto 28rpx;
  display: flex;
  overflow: hidden;
  border-radius: 24rpx;
}

.thumb {
  width: 137rpx;
  height: 128rpx;
  border-right: 2rpx solid #fff;
}

.thumb-active {
  opacity: 0.72;
}

.image-count {
  position: absolute;
  right: 48rpx;
  top: 630rpx;
  padding: 0 16rpx;
  height: 40rpx;
  border-radius: 16rpx;
  background: rgba(0, 0, 0, 0.2);
  color: #fff;
  line-height: 40rpx;
  font-size: 22rpx;
}

.car-head {
  width: 686rpx;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.detail-name {
  font-size: 38rpx;
  line-height: 48rpx;
  font-weight: 600;
}

.detail-price {
  padding-top: 4rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.detail-price .big {
  font-size: 38rpx;
}

.feature-row {
  width: 686rpx;
  margin: 20rpx auto 32rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.highlight-row {
  width: 686rpx;
  margin: -8rpx auto 28rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.highlight-pill {
  min-height: 56rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #fff7df;
  color: #2b2627;
  line-height: 56rpx;
  font-size: 22rpx;
}

.store-card {
  width: 686rpx;
  margin: 0 auto 24rpx;
  border-radius: 24rpx;
  background: #f8f8f7;
}

.compact-head {
  width: auto;
  height: 72rpx;
  padding: 0 24rpx;
  margin: 0;
  font-size: 28rpx;
}

.store-main {
  padding: 0 24rpx 24rpx;
}

.store-title {
  font-size: 28rpx;
  font-weight: 600;
}

.store-meta {
  margin-top: 10rpx;
  color: rgba(43, 38, 39, 0.56);
  font-size: 22rpx;
}

.feature-box {
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #f7f7f7;
  color: rgba(43, 38, 39, 0.6);
  line-height: 64rpx;
  font-size: 22rpx;
}

.divider {
  height: 16rpx;
  background: #f8f8f7;
}

.section-head {
  width: 686rpx;
  height: 84rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 34rpx;
  font-weight: 600;
}

.mini-more {
  width: 48rpx;
  height: 48rpx;
  border: 1rpx solid #eaeaea;
  border-radius: 16rpx;
  line-height: 44rpx;
}

.calendar-card {
  width: 686rpx;
  margin: 0 auto 28rpx;
}

.calendar-range {
  height: 160rpx;
  padding: 32rpx 48rpx;
  border: 4rpx solid #2b2627;
  border-radius: 32rpx;
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.range-date {
  font-size: 34rpx;
  font-weight: 600;
}

.range-pill {
  min-width: 88rpx;
  height: 64rpx;
  border: 1rpx solid #eaeaea;
  border-radius: 32rpx;
  text-align: center;
  line-height: 62rpx;
}

.right {
  text-align: right;
}

.week-row,
.day-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  margin-top: 24rpx;
}

.week-row {
  color: rgba(43, 38, 39, 0.6);
  font-size: 24rpx;
}

.day-cell {
  min-height: 86rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  font-size: 38rpx;
  font-weight: 600;
}

.day-cell > text:first-child {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 1rpx solid #eaeaea;
  line-height: 78rpx;
}

.day-on > text:first-child {
  background: #fcd41d;
  border-color: #fcd41d;
}

.day-off > text:first-child {
  color: #fff;
  background: rgba(252, 81, 29, 0.72);
  border-color: #fd744a;
}

.day-price {
  color: rgba(43, 38, 39, 0.36);
  font-size: 22rpx;
  font-weight: 400;
}

.legend {
  margin-top: 28rpx;
  display: flex;
  justify-content: center;
  gap: 22rpx;
  color: rgba(43, 38, 39, 0.6);
  font-size: 22rpx;
}

.orange {
  color: rgba(252, 81, 29, 0.8);
}

.calendar-tip {
  margin-top: 18rpx;
  color: rgba(43, 38, 39, 0.52);
  font-size: 22rpx;
  line-height: 34rpx;
}

.spec-grid {
  width: 686rpx;
  margin: 0 auto 24rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  row-gap: 28rpx;
}

.spec-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 28rpx;
  line-height: 40rpx;
}

.desc-dot {
  width: 686rpx;
  margin: 8rpx auto 24rpx;
  font-size: 26rpx;
  line-height: 48rpx;
}

.detail-photo {
  display: block;
  width: 686rpx;
  height: 320rpx;
  margin: 0 auto 16rpx;
  border-radius: 24rpx;
}

.notice-card {
  width: 686rpx;
  margin: 0 auto 16rpx;
  border: 1rpx solid #fcf0b9;
  border-radius: 24rpx;
  overflow: hidden;
  background: #fff;
}

.notice-title {
  height: 80rpx;
  padding: 24rpx 32rpx 0;
  background: linear-gradient(115deg, #fef8de 0%, #fef8de 44%, #fff 44%, #fff 100%);
  font-weight: 600;
}

.notice-body {
  padding: 24rpx 32rpx 28rpx;
}

.notice-body view {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
}

.notice-body view:last-child {
  margin-bottom: 0;
}

.notice-body.stacked view {
  justify-content: flex-start;
}

.pay-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  height: calc(128rpx + env(safe-area-inset-bottom));
  padding: 24rpx 32rpx env(safe-area-inset-bottom);
  display: flex;
  gap: 32rpx;
  background: #fff;
  border-top: 1rpx solid #f5f5f5;
}

.pay-price {
  width: 128rpx;
}

.pay-num {
  font-size: 52rpx;
  font-weight: 700;
}

.fee-tag {
  display: inline-block;
  min-width: 128rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx 16rpx 4rpx 16rpx;
  background: #fcd41d;
  font-size: 22rpx;
}

.pay-btn {
  flex: 1;
}
