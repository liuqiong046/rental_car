page {
  min-height: 100%;
  background: #f8f8f7;
  color: #2b2627;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Source Han Sans SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
scroll-view,
image,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  background: transparent;
  border-radius: 0;
  line-height: inherit;
  font-size: inherit;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
}

.page-soft {
  background: #f8f8f7;
}

.nav {
  position: sticky;
  top: 0;
  z-index: 20;
  min-height: 88px;
  padding: 0 24rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.nav-light {
  background: linear-gradient(180deg, #fef8dc 0%, rgba(254, 248, 220, 0.72) 48%, rgba(255, 255, 255, 0) 100%);
}

.nav-dark {
  color: #fff;
}

.nav-title {
  height: 32px;
  line-height: 32px;
  font-size: 34rpx;
  font-weight: 500;
  max-width: 360rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-back {
  position: absolute;
  left: 24rpx;
  top: 54px;
  width: 48rpx;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  font-size: 42rpx;
}

.wechat-capsule {
  position: absolute;
  right: 12rpx;
  top: 102rpx;
  width: 174rpx;
  height: 64rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(43, 38, 39, 0.14);
  background: rgba(255, 255, 255, 0.62);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 22rpx;
  color: rgba(43, 38, 39, 0.58);
  font-weight: 700;
}

.section-title {
  padding: 0 32rpx;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 40rpx;
}

.card {
  width: 686rpx;
  margin: 0 auto;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(88, 62, 6, 0.03);
}

.muted {
  color: rgba(43, 38, 39, 0.6);
}

.weak {
  color: rgba(43, 38, 39, 0.4);
}

.btn-yellow {
  height: 88rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fddc45 0%, #fcd41d 100%);
  color: #2b2627;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-dark {
  height: 104rpx;
  border-radius: 24rpx;
  background: #2b2627;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.pill {
  border-radius: 32rpx;
  border: 1rpx solid rgba(43, 38, 39, 0.1);
  background: #fff;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  min-height: 132rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  border-top: 1rpx solid #f0f0ef;
}

.tabbar {
  height: 100rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.tab-item {
  width: 160rpx;
  text-align: center;
  color: rgba(62, 68, 71, 0.58);
  font-size: 22rpx;
  line-height: 28rpx;
}

.tab-icon {
  display: block;
  margin: 0 auto 6rpx;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  font-size: 34rpx;
}

.tab-active {
  color: #3e4447;
  font-weight: 500;
}
